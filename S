Задача 4*. Максимум из 5 чисел

```c
#include <stdio.h>
#include <Windows.h>

void main() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int a[5], i, max;

    printf("Введите 5 чисел: ");
    for (i = 0; i < 5; i++)
        scanf_s("%d", &a[i]);

    max = a[0];
    for (i = 1; i < 5; i++)
        if (a[i] > max) max = a[i];

    printf("Максимум: %d\n", max);
}
```

