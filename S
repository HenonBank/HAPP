Задача 4. Покупка квартиры с накоплением

```c
#include <stdio.h>
#include <Windows.h>

void main() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    float area, price_per_m2, salary, total, months;

    printf("Введите площадь квартиры (м²): ");
    scanf_s("%f", &area);

    printf("Введите стоимость 1 м²: ");
    scanf_s("%f", &price_per_m2);

    printf("Введите зарплату в месяц: ");
    scanf_s("%f", &salary);

    total = area * price_per_m2;
    months = total / (salary * 0.5);

    printf("Стоимость квартиры: %.2f руб\n", total);
    printf("Месяцев копить (50%% зарплаты): %.0f\n", months);
}
```

