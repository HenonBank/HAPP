        } else {
            printf("\nрҹҸҶрҹҸҶрҹҸҶ РҹРһР—Р”Р РҗР’РӣРҜР®! Р’Р« РҹР РһРЁРӣРҳ Р’РЎР• 5 РқРһР§Р•Рҷ! рҹҸҶрҹҸҶрҹҸҶ\n");
            printf("РӨРҳРқРҗРӣР¬РқР«Рҷ РЎР§РҒРў: %d РјРҫРҪРөСӮ\n", state.coins);
            break;
        }
    }
    
    printf("\nРқР°Р¶РјРёСӮРө ENTER РҙР»СҸ РІСӢС…РҫРҙР°...");
