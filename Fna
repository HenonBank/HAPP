void initNight() {
    for (int i = 0; i < MAX_ANIM; i++) {
        anims[i].position = 0;
        anims[i].active = 1;
        
        if (i == 4 && state.night < 3) {
            anims[i].active = 0;
        }
        
        if (i == 3 && state.night >= 3) {
            anims[i].aggression = 10;
        }
    }
    
    state.hour = 0;
    state.leftDoorClosed = 0;
    state.rightDoorClosed = 0;
    state.ventBlocked = 0;
    state.cameraOn = 0;
    state.flashlightOn = 0;
    state.flashlightBattery = 100;
    state.audioPlaying = 0;
    
    state.maxPower = BASE_POWER + (upgrades.batteryLevel * 5);
    state.power = state.maxPower;
}

