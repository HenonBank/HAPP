void flashlightMinigame() {
    if (state.flashlightBattery <= 0) {
        printf("\nвқҢ Р‘Р°СӮР°СҖРөР№РәР° С„РҫРҪР°СҖРёРәР° СҒРөР»Р°!\n");
        return;
    }
    
    printf("\nрҹ”Ұ Р’РҡРӣР®Р§РҗР•Рң РӨРһРқРҗР РҳРҡ рҹ”Ұ\n");
    printf("Р§СӮРҫ-СӮРҫ РҙРІРёР¶РөСӮСҒСҸ РІ СӮРөРјРҪРҫСӮРө...\n");
    SLEEP(1000);
    
    int found = 0;
    for (int i = 0; i < MAX_ANIM; i++) {
        if (anims[i].active && anims[i].position == 1) {
            printf("рҹ’Җ %s РұСӢР» СҖСҸРҙРҫРј СҒ РІР°РјРё! Р’СӢ РөРіРҫ СҒРҝСғРіРҪСғР»Рё!\n", anims[i].name);
            anims[i].position = 0;
            found = 1;
        }
    }
    
    if (!found) {
        printf("РқРёРәРҫРіРҫ... Р’РҫР·РјРҫР¶РҪРҫ, РҝРҫРәР°Р·Р°Р»РҫСҒСҢ.\n");
    }
    
    int cost = 5 - upgrades.flashlightUpgrade;
    if (cost < 2) cost = 2;
    state.flashlightBattery -= cost;
    if (state.flashlightBattery < 0) state.flashlightBattery = 0;
    
    state.flashlightOn = 0;
    SLEEP(800);
}

