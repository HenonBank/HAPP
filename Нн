#include <stdio.h>
#include <Windows.h>

void main() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    float m;           // Площадь желаемой квартиры
    int rub_m;         // Сколько рублей стоит 1 квадратный метр
    float salary;      // Зарплата в месяц
    float price;       // Стоимость квартиры
    float months;      // Месяцев накопления

    // Ввод площади
    printf("Введите площадь квартиры (м²): ");
    scanf_s("%f", &m);

    // Ввод стоимости за квадратный метр
    printf("Введите стоимость 1 квадратного метра квартиры (RUB): ");
    scanf_s("%d", &rub_m);

    // Ввод зарплаты
    printf("Введите зарплату в месяц (RUB): ");
    scanf_s("%f", &salary);

    // Вычисление стоимости квартиры
    price = m * rub_m;

    // Вычисление времени накопления (50% зарплаты)
    months = price / (salary * 0.5);

    // Вывод результатов
    printf("\n--- РЕЗУЛЬТАТ ---\n");
    printf("Квартира площадью %.2f м² по цене %d RUB/м² стоит %.2f RUB\n", m, rub_m, price);
    printf("При зарплате %.2f RUB в месяц и откладывании 50%%:\n", salary);
    printf("Потребуется месяцев: %.1f\n", months);
    printf("Потребуется лет: %.2f\n", months / 12);
}
